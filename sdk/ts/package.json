{
  "name": "@vmon/sdk",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "generate": "../../target/debug/vmon openapi > openapi.json && openapi-typescript openapi.json -o src/schema.d.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/bun": "^1.2.0",
    "openapi-typescript": "^7.8.0",
    "typescript": "^5.6.3"
  }
}
