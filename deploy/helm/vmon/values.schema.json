{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Vibemon cluster values",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "existingSecret": { "type": "string" },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "global": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "clusterMode": { "type": "string", "enum": ["production", "single-node"] }
      },
      "required": ["clusterMode"]
    },
    "nodes": {
      "type": "object",
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 1 },
        "apiToken": { "type": "string" },
        "clientToken": { "type": "string" },
        "portableHistoryKeyId": { "type": "string", "pattern": "^[A-Za-z0-9_.-]{1,128}$", "not": { "const": "default" } },
        "portableHistoryKey": { "type": "string" },
        "region": { "type": "string" },
        "hostNetwork": { "type": "boolean" },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string" }
          },
          "required": ["repository"]
        },
        "service": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
          },
          "required": ["type", "port"]
        },
        "nodeSelector": { "type": "object" },
        "tolerations": { "type": "array" },
        "affinity": { "type": "object" },
        "resources": { "type": "object" },
        "securityContext": { "type": "object" },
        "livenessProbe": { "type": "object" },
        "readinessProbe": { "type": "object" }
      },
      "required": ["replicaCount", "apiToken", "portableHistoryKeyId", "portableHistoryKey", "image", "service"]
    },
    "buildkit": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "address": { "type": "string" },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string", "minLength": 1 },
            "pullPolicy": { "type": "string" }
          },
          "required": ["repository", "tag"]
        },
        "resources": { "type": "object" },
        "persistence": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "storageClass": { "type": "string" },
            "size": { "type": "string" }
          },
          "required": ["enabled", "size"]
        }
      },
      "required": ["enabled", "address", "image", "persistence"]
    },
    "postgresql": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "image": { "type": "object" },
        "persistence": { "type": "object" },
        "auth": {
          "type": "object",
          "properties": {
            "database": { "type": "string", "minLength": 1 },
            "username": { "type": "string", "minLength": 1 },
            "password": { "type": "string", "minLength": 8 }
          },
          "required": ["database", "username", "password"]
        }
      },
      "required": ["enabled", "auth"]
    },
    "externalDatabase": {
      "type": "object",
      "properties": {
        "host": { "type": "string" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "database": { "type": "string" },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "sslmode": { "type": "string", "enum": ["disable", "prefer", "require", "verify-ca", "verify-full"] }
      }
    },
    "s3Storage": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "image": { "type": "object" },
        "clientImage": { "type": "object" },
        "persistence": { "type": "object" },
        "auth": {
          "type": "object",
          "properties": {
            "accessKey": { "type": "string", "minLength": 8 },
            "secretKey": { "type": "string", "minLength": 8 },
            "bucket": { "type": "string", "minLength": 1 },
            "region": { "type": "string", "minLength": 1 },
            "prefix": { "type": "string" }
          },
          "required": ["accessKey", "secretKey", "bucket", "region"]
        }
      },
      "required": ["enabled", "auth"]
    },
    "externalS3": {
      "type": "object",
      "properties": {
        "endpoint": { "type": "string" },
        "bucket": { "type": "string" },
        "region": { "type": "string" },
        "accessKey": { "type": "string" },
        "secretKey": { "type": "string" },
        "forcePathStyle": { "type": "boolean" },
        "prefix": { "type": "string" }
      }
    },
    "ingress": { "type": "object" }
  },
  "required": ["global", "nodes", "buildkit", "postgresql", "s3Storage"],
  "allOf": [
    {
      "if": { "properties": { "postgresql": { "properties": { "enabled": { "const": false } } } } },
      "then": {
        "properties": {
          "externalDatabase": { "required": ["host", "database", "username"] }
        },
        "required": ["externalDatabase"]
      }
    },
    {
      "if": {
        "allOf": [
          { "properties": { "postgresql": { "properties": { "enabled": { "const": false } } } } },
          { "properties": { "existingSecret": { "maxLength": 0 } } }
        ]
      },
      "then": {
        "properties": {
          "externalDatabase": { "required": ["password"] }
        }
      }
    },
    {
      "if": { "properties": { "s3Storage": { "properties": { "enabled": { "const": false } } } } },
      "then": {
        "properties": {
          "externalS3": { "required": ["endpoint", "bucket"] }
        },
        "required": ["externalS3"]
      }
    },
    {
      "if": {
        "allOf": [
          { "properties": { "s3Storage": { "properties": { "enabled": { "const": false } } } } },
          { "properties": { "existingSecret": { "maxLength": 0 } } }
        ]
      },
      "then": {
        "properties": {
          "externalS3": { "required": ["accessKey", "secretKey"] }
        }
      }
    },
    {
      "if": {
        "allOf": [
          { "properties": { "global": { "properties": { "clusterMode": { "const": "production" } } } } },
          { "properties": { "existingSecret": { "maxLength": 0 } } }
        ]
      },
      "then": {
        "properties": {
          "nodes": {
            "properties": {
              "portableHistoryKey": { "pattern": "^[0-9A-Fa-f]{64}$" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "buildkit": { "properties": { "enabled": { "const": false } } } } },
      "then": {
        "properties": {
          "buildkit": { "properties": { "address": { "minLength": 1 } } }
        }
      }
    }
  ]
}
