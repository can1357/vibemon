# EditorConfig — https://editorconfig.org
# Indentation mirrors each language's formatter: Rust uses hard tabs rendered as
# 3 columns (see rustfmt.toml); everything else uses spaces.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.rs]
indent_style = tab
tab_width = 3
max_line_length = 100

[*.py]
indent_size = 4

[justfile]
indent_size = 4

[*.md]
trim_trailing_whitespace = false
