#!/bin/sh
# vmon-lima — drive the vmon CLI inside a Lima KVM VM from macOS.
#
# Native macOS/HVF support is now available on Apple silicon for aarch64 guests:
# build the local `vmm` with `just build`, then run the normal `vmon` CLI
# natively when you do not need Lima. Keep this wrapper for x86_64 guests,
# nested Linux/KVM coverage, or Linux-only features such as TAP networking.
#
# When using Lima, the hypervisor (vmon), its Unix sockets, the Python venv, and
# (for `vmon run`) docker/podman all live INSIDE the guest. This wrapper just
# relays your command there via `limactl shell`, so on the Mac you can type:
#
#   ./demo/vmon-lima ps
#   ./demo/vmon-lima run alpine -- sh -c 'uname -a'
#
# Assumes the repo is checked out at ~/vmon in the guest with a venv at
# python/.venv and a built binary at target/{debug,release}/vmm.
# Override the VM name with VMON_LIMA_VM (default: kvm).
set -eu
VM="${VMON_LIMA_VM:-kvm}"
exec limactl shell "$VM" -- bash -lc '
  cd "$HOME/vmon/python" || exit 1
  . .venv/bin/activate 2>/dev/null || true
  bin="$HOME/vmon/target/release/vmm"
  [ -x "$bin" ] || bin="$HOME/vmon/target/debug/vmm"
  export VMON_BIN="$bin" PYTHONPATH=.
  exec python3 -m vmon "$@"
' vmon "$@"
